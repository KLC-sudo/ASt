# --- Database ---
DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"

# --- CMS global sync (static site -> API) ---
CMS_PUBLISH_SECRET="generate-with-openssl-rand-base64-32"

# --- Auth ---
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-api.example.com"

# --- Webhook (Android device → API) ---
WEBHOOK_SECRET="generate-with-openssl-rand-base64-32"

# --- Email ---
RESEND_API_KEY="re_xxx"
EMAIL_FROM="Lorem Ipsum <noreply@your-domain.com>"

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxx"

# --- Cross-service ---
STATIC_SITE_URL="https://your-domain.com"

# --- Payment providers (placeholder values) ---
FORNAX_MERCHANT_CODE="XXXX"
VENTUS_NUMBER="+0000000000"
PAYMENT_SUPPORT_PHONE="+0000000000"
